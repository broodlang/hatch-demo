/_deps/

# Asset toolchain — fetched by bin/setup, regenerable, not committed.
/bin/tailwindcss
/assets/vendor/

# Generated stylesheet — built from assets/app.css by bin/tailwindcss.
/static/app.css

# Content-fingerprinted assets + manifest — produced by the release build
# (web/assets/fingerprint); regenerable, not committed.
/static/app.*.css
/static/cache-manifest
