(defmodule main
  "Entry point for hatch-demo."
  (:use web/endpoint :only [serve])
  (:use web/application :only [start default-logger-opts])
  (:alias db)
  (:alias pg))

(defn main ()
  "Start logging, open the DB pool, boot the endpoint, and park."
  (start
    {:logger   (default-logger-opts)
     :children [(fn () (db/start (pg/opts-from-env "hatch_demo")))
                (fn () (serve))]}))
